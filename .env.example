# ─────────────────────────────────────────────────────────────
# VILLETO VENDOR — Environment Variables
# Copy this file to .env.local and fill in the values.
# ─────────────────────────────────────────────────────────────

# ── Backend API ───────────────────────────────────────────────
# Base URL for all API calls (no trailing slash)
NEXT_PUBLIC_API_URL=https://api.villeto.app/v1

# ── App URL ───────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Auth ─────────────────────────────────────────────────────
# JWT secret used by Edge middleware to decode tokens without DB hit
# Must match the secret used to sign tokens on the backend
JWT_SECRET=your-jwt-secret-here

# ── Cookie Config ─────────────────────────────────────────────
# Auth cookie expiry in days
COOKIE_EXPIRY_DAYS=7

# ── Payment Providers ─────────────────────────────────────────
# (Used server-side in the backend, not frontend — listed here for reference)
# PAYSTACK_SECRET_KEY=sk_live_xxx
# FLUTTERWAVE_SECRET_KEY=FLWxxx

# ── Feature Flags ────────────────────────────────────────────
# Set to "true" to enable React Query devtools in production (not recommended)
NEXT_PUBLIC_ENABLE_DEVTOOLS=false
